<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="x-apple-disable-message-reformatting">
    <title>New Tender Posted</title>
    <style>
        body,
        table,
        td,
        a {
            text-size-adjust: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            width: 100%;
            height: 100%;
            font-family: Arial, Roboto, Inter, sans-serif;
            color: #3a3e49;
            background: #fff;
        }

        table {
            border-collapse: collapse !important;
            width: 100%;
        }

        .email-container {
            max-width: 600px;
            margin: 40px auto;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            border: 1px solid #272727;
            overflow: hidden;
        }

        .email-header {
            background: #0090F3;
            color: #fff;
            text-align: center;
            padding: 20px;
        }

        .email-header img {
            width: 180px;
            height: auto;
            margin-bottom: 14px;
        }

        .email-header h1 {
            font-size: 20px;
            margin: 0;
            font-weight: 600;
        }

        .email-body {
            padding: 30px;
            color: #3a3e49;
        }

        .email-body h2 {
            color: #0090F3;
            font-size: 20px;
            font-weight: 600;
            margin: 0 0 15px;
        }

        .email-body p {
            margin: 15px 0;
            font-size: 16px;
            color: #767676;
        }

        .button {
            display: inline-block;
            padding: 12px 25px;
            font-size: 16px;
            border-radius: 6px;
            background: #0090F3;
            color: #fff;
            text-decoration: none;
            text-align: center;
        }

        .button:hover {
            background: #0078DC;
        }

        .email-footer {
            background: #3a3e49;
            text-align: center;
            padding: 20px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.7);
            border-top: 1px solid #272727;
        }
    </style>
</head>

<body>
    <center>
        <table class="email-container">
            <tr>
                <td class="email-header">
                    <img src="{{backend_url}}/images/defaults/app-logo.svg" alt="{{company_name}} Logo">
                    <h1>New Tender Submission</h1>
                </td>
            </tr>
            <tr>
                <td class="email-body">
                    <h2>Hello, Admin</h2>
                    <p>A new tender has been submitted by <strong>{{organization_name}}</strong>. Please review and
                        approve it.</p>
                    <p><strong>Tender Title:</strong> {{tender_title}}</p>
                    <p><strong>Submission Date:</strong> {{submission_date}}</p>
                    <p style="text-align: center;">
                        <a href="{{approval_link}}" class="button">Review & Approve</a>
                    </p>
                </td>
            </tr>
            <tr>
                <td class="email-footer">
                    &copy; {{year}} {{company_name}}. All rights reserved.
                </td>
            </tr>
        </table>
    </center>
</body>

</html>